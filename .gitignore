node_modules/
dist/
# Ignore every env variant except the committed template.
.env
.env.*
!.env.example
*.log
.DS_Store
.vitest-cache/
coverage/

# Runtime artifacts that change every run — kept out of commits
data/runs/
data/cost-counter.json
data/score-history.jsonl

# Generated images cached locally
data/images/

# Markdown exports written by the publish adapter (per-site, per-post)
data/exports/

# Database backups produced by scripts/backup.sh
data/backups/

# Per-tenant business intelligence (GSC analytics, competitor crawls, run logs).
# Keep out of local/VPS commits. NOTE: the GitHub Actions cron deployment still
# commits these back as its persistence mechanism — moving that to a volume or
# private object storage is a pending decision (see audit).
data/gsc-snapshots/
data/competitor-snapshots/
data/internal-linker-runs/
data/content-decay-runs/
data/cwv-runs/

# SQLite database (per-machine runtime state)
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# TypeScript incremental build info (machine-local)
*.tsbuildinfo

# Superpowers brainstorm/runtime scratch state (machine-local)
.superpowers/
