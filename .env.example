# =============================================================================
# Blog Studio — environment template
#
# Copy to `.env` and fill in. Never commit `.env`.
#
#   cp .env.example .env
#   $EDITOR .env
#
# Used by:
#   • Docker Compose            -> `env_file: .env` in docker-compose.yml
#   • Systemd                   -> place at /etc/blogtool/blogtool.env (0600)
#   • Local dev (apps/web)      -> Next.js auto-loads ./.env from apps/web/,
#                                  so symlink or copy this file there too.
#
# A mirror lives at apps/web/.env.example for the dev workflow.
# =============================================================================


# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
# `production` | `development` | `test`. Dockerfile/systemd force `production`.
NODE_ENV=production

# Port Next.js binds to inside the container / on the host.
PORT=3000

# Host-side port the docker-compose service binds to. Defaults to 3000.
# Useful if 3000 is already taken or you front multiple apps with one proxy.
BLOGTOOL_PORT=3000

# SQLite database location.
#   • Docker:      /app/data/app.db (forced in docker-compose.yml)
#   • Bare metal:  /opt/blogtool/data/app.db (or wherever you ran `git clone`)
# Code reads DATABASE_FILE first; DATABASE_URL is only used by drizzle-kit
# (migrations / studio) and accepts a libsql `file:` URL.
DATABASE_FILE=/app/data/app.db
DATABASE_URL=file:/app/data/app.db


# -----------------------------------------------------------------------------
# Cron / scheduling
# -----------------------------------------------------------------------------
# REQUIRED for `/api/cron/[siteSlug]` to accept invocations. Generate with:
#   openssl rand -hex 32
# Then schedule e.g. from host crontab:
#   */15 * * * * curl -fsS "https://blog.example.com/api/cron/<site-slug>?token=$CRON_TOKEN"
# If unset, the cron endpoint returns 503 (fail-safe — no anonymous runs).
CRON_TOKEN=


# -----------------------------------------------------------------------------
# AI providers
# -----------------------------------------------------------------------------
# Sites can also store their own keys in the DB (Settings → API keys); the
# values here are the global fallback used when a site has none configured.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Jina Reader — free crawler used to convert URLs to clean markdown.
# Public endpoint works key-less for low volume; set a key to lift rate limits.
JINA_API_KEY=

# Image generation
FAL_API_KEY=
# Optional Cloudflare Workers AI image fallback.
CF_ACCOUNT_ID=
CF_API_TOKEN=


# -----------------------------------------------------------------------------
# GSC (Google Search Console)
# -----------------------------------------------------------------------------
# Global service-account JSON used for topic-suggester / content-decay /
# CWV jobs. Two ways to provide it:
#
#   1) Inline (recommended for Docker — single env file):
#        GSC_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":...}'
#      Mind the single quotes — the JSON contains `"` chars.
#
#   2) File path (handy for systemd with a mounted secret):
#        GSC_SERVICE_ACCOUNT_JSON=/etc/blogtool/gsc-service-account.json
#      The code accepts either a JSON string or a path.
#
# Per-site overrides live in the DB (Settings → Google Search Console) so
# multi-site deployments don't need this at all.
GSC_SERVICE_ACCOUNT_JSON=

# PageSpeed Insights — only needed if a tenant enables cwv_monitoring.
PSI_API_KEY=

# IndexNow — single shared key, hosted at https://<domain>/<key>.txt per site.
INDEXNOW_KEY=


# -----------------------------------------------------------------------------
# Publishing — WordPress
# -----------------------------------------------------------------------------
# Per-site WordPress credentials live in the DB (Settings → Publish destination)
# so multi-site setups don't need them here. These are *fallback* values that
# the legacy single-tenant pipeline (`src/pipeline/orchestrator.ts`) still
# reads when invoked directly.
WP_USER=agent-blog
WP_APP_PASSWORD=


# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# Used to mail draft previews to the redactie inbox.
RESEND_API_KEY=


# -----------------------------------------------------------------------------
# Reverse proxy — Caddy (optional)
# -----------------------------------------------------------------------------
# Set if you uncomment the `caddy` service in docker-compose.yml.
# BLOGTOOL_DOMAIN=blog.example.com
# ACME_EMAIL=ops@example.com


# -----------------------------------------------------------------------------
# Scheduler (in-process)  — see docs/deployment/scheduling.md
# -----------------------------------------------------------------------------
# The webapp boots an in-process cron scheduler that reads each site's
# `schedule_cron` field and triggers runs. In production it starts
# automatically; in dev it's off unless ENABLE_SCHEDULER_IN_DEV=true.
#
# Disable entirely (e.g. when using systemd timer or an external scheduler
# behind a load balancer / multi-process deployment):
DISABLE_INPROCESS_SCHEDULER=

# Force scheduler on in development (default off in dev):
ENABLE_SCHEDULER_IN_DEV=

# How often (ms) the scheduler re-polls the DB for site/cron changes.
# Minimum 15000. Default 60000.
SCHEDULER_POLL_INTERVAL_MS=60000

# IANA timezone for cron-expressions (e.g. "Europe/Amsterdam").
# If unset, the OS timezone is used — on a UTC VPS that means cron
# expressions are evaluated in UTC. Set this explicitly in production.
SCHEDULER_TIMEZONE=Europe/Amsterdam


# -----------------------------------------------------------------------------
# Encryption-at-rest for site secrets  — see docs/security/secrets.md
# -----------------------------------------------------------------------------
# Required in production, recommended in dev. Base64-encoded 32 bytes.
# Generate via either:
#   openssl rand -base64 32
#   npx tsx apps/web/scripts/generate-encryption-key.ts
#
# Encrypts the `api_keys` JSON and `wordpressConfig.appPassword` columns
# in the `sites` table (AES-256-GCM, per-value IV).
#
# LOSE THIS KEY = LOSE ACCESS to all stored API keys + WP passwords.
# Back it up SEPARATELY from data/app.db.
#
# On first boot with this key set, plaintext rows are auto-migrated in place
# (idempotent). In NODE_ENV=production the app refuses to start without it.
# Without a valid key, writing a secret FAILS CLOSED unless you explicitly set
# ALLOW_PLAINTEXT_SECRETS=true (dev-only escape hatch).
APP_ENCRYPTION_KEY=
ALLOW_PLAINTEXT_SECRETS=


# -----------------------------------------------------------------------------
# Auth — login rate-limit (sliding window per IP)
# -----------------------------------------------------------------------------
# Defaults: 5 failed attempts per 15 min per IP. Successful logins don't
# consume the budget. After exceeding, login returns 429 with a "retry in X
# min" message until the window slides.
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5


# -----------------------------------------------------------------------------
# Error monitoring — see docs/operations/error-monitoring.md
# -----------------------------------------------------------------------------
# Primary aggregation is the SQLite `error_events` table + /errors UI in the
# webapp. Everything below is optional fan-out.

# Auto-prune retention. Default = max(90 days, 5000 events): a quiet month
# keeps everything, a noisy week is bounded.
ERROR_RETENTION_DAYS=90
ERROR_MAX_EVENTS=5000

# OPTIONAL: Sentry forwarding. Install @sentry/node manually if you want it
# (no required dep). When SENTRY_DSN is set, every recordError() also fires
# Sentry.captureException(). Silently skipped if @sentry/node isn't installed.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=

# OPTIONAL: Email alerts via Resend (uses RESEND_API_KEY above). When set,
# 'fatal'-severity errors trigger an email — rate-limited to 1 per hour per
# source+message-hash to prevent mail-bombing during flap.
ERROR_ALERT_EMAIL=
ERROR_ALERT_FROM=
ERROR_ALERT_REPLY_TO=
