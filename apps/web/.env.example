# =============================================================================
# Blog Studio — environment template (apps/web mirror)
#
# The canonical template lives at the repo root as `.env.example`. This file
# is the mirror used by the Next.js dev workflow (`npm run dev` from
# apps/web/ auto-loads ./.env). The two files must stay in sync — when in
# doubt, copy the root one over this one.
#
# Local dev:
#   cp ../../.env.example .env       # then edit
#   npm run dev
# =============================================================================


# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# Path is relative to apps/web/ when running `npm run dev`, so `../../data/app.db`
# lands at <repo>/data/app.db — same place the agent pipeline uses.
DATABASE_FILE=../../data/app.db
DATABASE_URL=file:../../data/app.db


# -----------------------------------------------------------------------------
# Cron / scheduling
# -----------------------------------------------------------------------------
CRON_TOKEN=


# -----------------------------------------------------------------------------
# AI providers
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
JINA_API_KEY=
FAL_API_KEY=
CF_ACCOUNT_ID=
CF_API_TOKEN=


# -----------------------------------------------------------------------------
# GSC (Google Search Console)
# -----------------------------------------------------------------------------
# Inline JSON or a file path — see root .env.example for details.
GSC_SERVICE_ACCOUNT_JSON=
PSI_API_KEY=
INDEXNOW_KEY=


# -----------------------------------------------------------------------------
# Publishing — WordPress (fallback for legacy pipeline; per-site lives in DB)
# -----------------------------------------------------------------------------
WP_USER=agent-blog
WP_APP_PASSWORD=


# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
RESEND_API_KEY=


# -----------------------------------------------------------------------------
# Scheduler (in-process) — see docs/deployment/scheduling.md
# -----------------------------------------------------------------------------
# In dev the scheduler is OFF by default. Flip on for local testing:
ENABLE_SCHEDULER_IN_DEV=

# Set true to disable even in production (use systemd / external scheduler):
DISABLE_INPROCESS_SCHEDULER=

# Re-poll DB for site/cron changes every N ms. Min 15000, default 60000.
SCHEDULER_POLL_INTERVAL_MS=60000

# IANA timezone (e.g. "Europe/Amsterdam"). Defaults to OS TZ.
SCHEDULER_TIMEZONE=Europe/Amsterdam


# -----------------------------------------------------------------------------
# Encryption-at-rest for site secrets — see docs/security/secrets.md
# -----------------------------------------------------------------------------
# Base64-encoded 32 bytes. Generate with:
#   npx tsx apps/web/scripts/generate-encryption-key.ts
#
# Dev: app boots without it (loud warning, secrets stay plaintext).
# Prod: app refuses to start without it. Lose this = lose all stored API keys.
APP_ENCRYPTION_KEY=
